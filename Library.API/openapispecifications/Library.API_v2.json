{
  "openapi": "3.1.1",
  "info": {
    "title": "Library API",
    "description": "Through this API you can access authors and their books.",
    "contact": {
      "name": "Test Author",
      "email": "test@test.com"
    },
    "license": {
      "name": "MIT License",
