    "version": "v2"
  },
  "paths": {
    "/api/authors/{authorId}/books/{bookId}": {
      "get": {
        "tags": [
          "Books"
        ],
        "summary": "Get a book by id",
        "description": "Returns a single book with title and description for a specific author",
        "operationId": "GetBook",
        "parameters": [
          {
            "name": "authorId",
            "in": "path",
            "description": "The id of the author",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "bookId",
            "in": "path",
            "description": "The id of the book to get",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Book"
                }
              }
            }
          },
          "404": {
            "description": "Not found - the requested resource does not exist. The response body contains a Problem Details object."
          },
          "400": {
            "description": "Bad request - the input failed validation. The response body contains a Problem Details object.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "default": {
            "description": "An unexpected error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/authors/{authorId}/books": {
      "post": {
        "tags": [
          "Books"
        ],
        "summary": "Create a book for an author",
        "description": "Creates a new book for a specific author",
        "parameters": [
          {
            "name": "authorId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BookForCreation"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "The resource was created. The Location of the header contains the URI of the new resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Book"
                }
              }
            }
          },
          "404": {
            "description": "Not found - the requested resource does not exist. The response body contains a Problem Details object."
          },
          "400": {
            "description": "Bad request - the input failed validation. The response body contains a Problem Details object.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          },
          "default": {
            "description": "An unexpected error occurred",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
