{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*"
	"ConnectionStrings": {
		"DishesDBConnectionString": "Data Source=Dishes.db"
	},
	"Authentication": {
		"DefaultScheme": "Bearer",
		"Schemes": {
			"Bearer": {
				"ValidAudiences": [
					"menu-api"
				],
				"ValidIssuers": "the_component_that_created_the_token"
			}
		}
	}
}